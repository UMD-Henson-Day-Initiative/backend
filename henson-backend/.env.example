
# Flask settings
FLASK_APP=autoapp.py
FLASK_DEBUG=0
FLASK_ENV=production

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/postgres?sslmode=require
# Supabase configuration
SUPABASE_URL=url
SUPABASE_KEY=key
# Public anon key (Dashboard → Settings → API → anon public) — used by /admin login in the browser only
SUPABASE_ANON_KEY=
# JWT Secret (Dashboard → Settings → API → JWT Secret) — server-only; when set, /collectibles/spawns/* require Bearer JWT + admin
SUPABASE_JWT_SECRET=
# Optional; default "authenticated"
# SUPABASE_JWT_AUDIENCE=authenticated
# Optional comma-separated emails treated as admin if app_metadata.admin is not set
# ADMIN_EMAILS=admin@example.com
SECRET_KEY=secret

# Gunicorn settings
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
LOG_LEVEL=info

SEND_FILE_MAX_AGE_DEFAULT = 0

# CORS settings
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
